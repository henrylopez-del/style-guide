  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var newsletterMsgs = document.querySelectorAll('.newsletter-subscribe');
      if (newsletterMsgs.length > 0) {
        var overlay = document.querySelector('.tw-op-newsletter-overlay');
        if (overlay) {
          newsletterMsgs.forEach(function(newsletterMsg) {
            overlay.parentNode.insertBefore(newsletterMsg, overlay.nextSibling);
          });
        }
      }
      
      document.querySelectorAll('.closeNewsletterMsg').forEach(function(closeBtn) {
        closeBtn.addEventListener('click', function() {
          closeBtn.closest('.newsletter-subscribe').style.display = 'none';
        });
      });
  
      document.addEventListener('click', function(event) {
        newsletterMsgs.forEach(function(newsletterMsg) {
          if (!newsletterMsg.contains(event.target)) {
            newsletterMsg.style.display = 'none';
          }
        });
      });
    });
  </script>
