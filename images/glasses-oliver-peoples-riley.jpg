    <style>#storePickupApp .checkoutMethod {
  border: none !important;
  border-radius: 0 !important;
  background: none !important;
  transition: background 0.3s ease;
  font-family: var(--text-h5-family) !important;
  font-size: var(--text-h5-size) !important;
  line-height: var(--text-h5-lineheight) !important;
  font-weight: var(--text-h5-weight) !important;
  letter-spacing: var(--text-h5-kerning) !important;
  color: var(--text-color-base-default) !important;
}

/* Metodo attivo → sfondo base */
#storePickupApp .checkoutMethod.active {
  background: var(--bg-color-base-default) !important;
}

/* Metodo non attivo → trasparente */
#storePickupApp .checkoutMethod:not(.active) {
  background: none !important;
}

/* Testo "Please select a pickup location:" */
#storePickupApp p.success {
  font-family: var(--text-h5-family) !important;
  font-size: var(--text-h5-size) !important;
  line-height: var(--text-h5-lineheight) !important;
  font-weight: var(--text-h5-weight) !important;
  letter-spacing: var(--text-h5-kerning) !important;
  color: var(--text-color-base-default) !important;
  margin-bottom: 1rem !important;
}

/* Riquadro locations → nessun background nessun bordo */
#storePickupApp .ZapietLocations-List .location {
  background: none !important;
  border: none !important;
  border-radius: 0 !important;
  font-family: var(--text-h5-family) !important;
  font-size: var(--text-h5-size) !important;
  line-height: var(--text-h5-lineheight) !important;
  font-weight: var(--text-h5-weight) !important;
  letter-spacing: var(--text-h5-kerning) !important;
  color: var(--text-color-base-default) !important;
  padding: 0.5rem 0 !important; 
  margin-bottom: 0.5rem !important; 
}

/* Location attiva → sfondo base per evidenziare la selezione */
#storePickupApp .checkoutMethodContainer .ZapietLocations-List .locations {
    background: var(--bg-color-base-default) !important;
    padding: var(--spacings-base)!important;
}
#storePickupApp .ZapietLocations-List .location.active {
  background: var(--bg-color-base-default) !important;
}

#storePickupApp .checkoutMethodContainer .locations .location input[type=radio] {
    accent-color: black !important;
}

#storePickupApp .checkoutMethodContainer .ZapietLocations-List .locations {
    border: none !important;
}
#storePickupApp .checkoutMethodContainer .locations  {
    border: none !important;
    border-radius: 0 !important;
}

.Zapiet-Modal__Wrapper {
    overflow: hidden !important;
}

.Zapiet-Modal__Wrapper .Zapiet-Modal__Content {
    height: 100%;
    max-width: 480px !important;
    min-width: 0 !important;
    position: absolute;
    right: 0 !important;
    left: auto !important;
    border-radius: 0 !important;
    padding: 2.4rem !important;
    gap: var(--spacings-xl) !important;
    transition: transform .5s cubic-bezier(.4,0,.2,1) !important;
    transform: translateX(100%) !important
}

.Zapiet-Modal__Wrapper .Zapiet-Modal__Content.is-open {
    transform: translateX(0) !important; 
}</style>




