            window.ZapietEvent.listen('widget_loaded', function() {
                const observer = new MutationObserver((mutations, obs) => {
    const appContainer = document.querySelector("#storePickupApp");
    appContainer?.addEventListener("click", (e) => {
        const target = e.target;
        if (target.classList.contains("moreInformationLink")){
            showModalZapied(target.dataset.modalId)  
        }
    })
    
    obs.disconnect();
});

observer.observe(document.body, { childList: true, subtree: true });

function showModalZapied(modalId){
    const modal = document.getElementById(modalId)
    setTimeout(() => {
        modal?.querySelector(".Zapiet-Modal__Content")?.classList.add("is-open")
    }, 100)
    modal.addEventListener("click", (e) => {
        if(e.target === modal || e.target.classList?.contains("Zapiet-Modal__Close-Button")){
            closeModalZapiet(modal)
        }
    })
}


function closeModalZapiet(modal){
    modal.querySelector(".Zapiet-Modal__Content").classList.remove("is-open")
}

if (window.Shopify.locale) { 
    Zapiet.setLanguage(window.Shopify.locale); 
}
            });
        
    }

    function loadZapietStyles(href) {
        var ss = document.createElement("link");
        ss.type = "text/css";
        ss.rel = "stylesheet";
        ss.media = "all";
        ss.href = href;
        document.getElementsByTagName("head")[0].appendChild(ss);
    }

    
        loadZapietStyles("https://cdn.shopify.com/extensions/019e49f8-cb7c-76ce-8f74-d3617224155a/zapiet-pickup-delivery-1268/assets/storepickup.css");
        var zapietLoadScripts = {
            vendor: true,
            storepickup: true,
            pickup: true,
            delivery: false,
            shipping: true,
            pickup_map: true,
            validator: false
        };

        function zapietScriptLoaded(key) {
            zapietLoadScripts[key] = false;
            if (!Object.values(zapietLoadScripts).includes(true)) {
                initializeZapietApp();
            }
        }
    
</script>




