  <script
      type="text/javascript"
  >
      (function (a, b, c, d) {
          a =
              '//tags.tiqcdn.com/utag/luxottica/oliverpeoples/prod/utag.js';
          b = document;
          c = 'script';
          d = b.createElement(c);
          d.src = a;
          d.type = 'text/java' + c;
          d.async = true;
          a = b.getElementsByTagName(c)[0];
          a.parentNode.insertBefore(d, a);
      })();

      let tealiumInterval;

      const params = new URLSearchParams(document.location.search);
      const customer_accept_market = params.get("customer_posted");

      const tealiumData = {
          id: "VirtualPage-View",
          Page_Type: "Error",
          Page_Section1: "Other", 
          Page_Section2: "ErrorHttp404",
          Page_Section3: "",
          Page_Country: "",
          Order_Currency: Shopify.currency.active,
          User_LoginStatus: "Guest",
          ...(customer_accept_market === 'true' && { Events_UserEmailSub: "1" }),
          User_LoginType: '',
          User_Email_MD5: "",
          User_Id: "",
          Products: window.tealium?.products ?? ""
      };

      const errorData = {
          Events_Error: "1",
          Error_Source : "404",
          Error_Code: "404 - page not found",
          Error_Details: window.location.href
      }

      const NEWSLETTER_FORM_SUBMISSION_STORAGE_KEY = 'newsletterFormSubmitted';
      const NEWSLETTER_FORM_SUBMISSION_MD5_STORAGE_KEY = 'newsletterFormSubmittedMd5';
      const CRYPTO_JS_ASSET_URL = "//www.oliverpeoples.com/cdn/shop/t/2/assets/crypto-js.min.js?v=85934245025572915161758708269";

      const DISALLOWED_KEYS = [
          'FrameType',
          'Engraving',
          'PriceSegment',
          'Sku',
          'Shape',
          'FrameTechnology',
          'LensTechnology',
          'Image',
          'Url',
          'Label',
          'LoyaltyExclusive',
          'Conf_IsUpcSupported',
          'SpeedyRx_Eligible'
      ];

      function stripDisallowedKeys(obj) {
          if (!obj || typeof obj !== 'object') return;
          DISALLOWED_KEYS.forEach((key) => {
              if (key in obj) delete obj[key];
          });
      }

      function sanitizeProducts(products) {
          if (!products) return;
          if (Array.isArray(products)) {
              products.forEach(stripDisallowedKeys);
              return;
          }
          if (typeof products === 'object') {
              Object.keys(products).forEach((id) => {
                  stripDisallowedKeys(products[id]);
              });
          }
      }

      function sanitizePayload(payload) {
          if (!payload || typeof payload !== 'object') return;
          stripDisallowedKeys(payload);
          if (payload.Products) sanitizeProducts(payload.Products);
          if (payload.products) sanitizeProducts(payload.products);
      }

      function normalizeEmailForHashing(email) {
          if (typeof email !== 'string') return '';
          return email.toLowerCase().trim().replace(/\s+/g, '');
      }

      function buildEmailMd5(email) {
          const normalizedEmail = normalizeEmailForHashing(email);
          if (!normalizedEmail) return '';

          return CryptoJS.MD5(normalizedEmail).toString();
      }

      function getStoredNewsletterSubmissionEmail() {
          const rawValue = sessionStorage.getItem(NEWSLETTER_FORM_SUBMISSION_STORAGE_KEY);
          if (!rawValue) return '';

          try {
              const parsedValue = JSON.parse(rawValue);
              if (parsedValue && typeof parsedValue === 'object') {
                  return normalizeEmailForHashing(parsedValue.email);
              }
          } catch (error) {
              // Backward compatibility for previously stored plain-string emails.
          }

          return normalizeEmailForHashing(rawValue);
      }

      function getStoredNewsletterSubmissionMd5() {
          return sessionStorage.getItem(NEWSLETTER_FORM_SUBMISSION_MD5_STORAGE_KEY) || '';
      }

      function loadCryptoJsScript() {
          if (typeof CryptoJS !== 'undefined') {
              return Promise.resolve();
          }

          if (window.__tealiumCryptoJsPromise) {
              return window.__tealiumCryptoJsPromise;
          }

          window.__tealiumCryptoJsPromise = new Promise((resolve, reject) => {
              const existingScript = document.querySelector(`script[src="${CRYPTO_JS_ASSET_URL}"]`);
              if (existingScript) {
                  if (typeof CryptoJS !== 'undefined' || existingScript.dataset.loaded === 'true') {
                      resolve();
                      return;
                  }

                  existingScript.addEventListener('load', () => {
                      existingScript.dataset.loaded = 'true';
                      resolve();
                  }, { once: true });
                  existingScript.addEventListener('error', reject, { once: true });
                  return;
              }

              const script = document.createElement('script');
              script.src = CRYPTO_JS_ASSET_URL;
              script.async = true;
              script.onload = () => {
                  script.dataset.loaded = 'true';
                  resolve();
              };
              script.onerror = reject;
              (document.head || document.body || document.documentElement).appendChild(script);
          });

          return window.__tealiumCryptoJsPromise;
      }

      function ensureNewsletterSubscriptionEmailMd5(payload) {
          if (!payload || payload.Events_UserEmailSub !== '1' || payload.User_Email_MD5) {
              return Promise.resolve();
          }

          const storedMd5 = getStoredNewsletterSubmissionMd5();
          if (storedMd5) {
              payload.User_Email_MD5 = storedMd5;
              return Promise.resolve();
          }

          const storedEmail = getStoredNewsletterSubmissionEmail();
          if (!storedEmail) {
              return Promise.resolve();
          }

          return loadCryptoJsScript()
              .then(() => {
                  const emailMd5 = buildEmailMd5(storedEmail);
                  if (!emailMd5) {
                      return;
                  }

                  payload.User_Email_MD5 = emailMd5;
                  sessionStorage.setItem(NEWSLETTER_FORM_SUBMISSION_MD5_STORAGE_KEY, emailMd5);
              })
              .catch((error) => {
                  console.error('Unable to hash newsletter email for Tealium', error);
              });
      }

      function sanitizeTealiumGlobals() {
          stripDisallowedKeys(window.utag_data);
          stripDisallowedKeys(window.utag?.data);
          if (window.tealium?.products) sanitizeProducts(window.tealium.products);
          if (window.utag_data?.Products) sanitizeProducts(window.utag_data.Products);
          if (window.utag?.data?.Products) sanitizeProducts(window.utag.data.Products);
      }

      function logTealiumPayload(label, payload) {
          try {
              // Avoid logging live references that might be mutated later
              const snapshot = JSON.parse(JSON.stringify(payload));
              console.log(label, snapshot);
          } catch (e) {
              console.log(label, payload);
          }
      }

      function patchTealiumPush() {
          if (window.__tealiumSanitizedPush) return;
          if (!window.tealium_data2track || typeof window.tealium_data2track.push !== 'function') return;
          const originalPush = window.tealium_data2track.push.bind(window.tealium_data2track);
          window.tealium_data2track.push = function (payload) {
              sanitizePayload(payload);
              sanitizeTealiumGlobals();
              logTealiumPayload('[Tealium] tealium_data2track.push', payload);
              return originalPush(payload);
          };
          window.__tealiumSanitizedPush = true;
      }

      function patchUtag() {
          if (window.__utagSanitized) return;
          if (!window.utag) return;
          if (typeof window.utag.view === 'function') {
              const originalView = window.utag.view.bind(window.utag);
              window.utag.view = function (payload, cb, uid) {
                  sanitizePayload(payload);
                  sanitizeTealiumGlobals();
                  logTealiumPayload('[Tealium] utag.view', payload);
                  return originalView(payload, cb, uid);
              };
          }
          if (typeof window.utag.link === 'function') {
              const originalLink = window.utag.link.bind(window.utag);
              window.utag.link = function (payload, cb, uid) {
                  sanitizePayload(payload);
                  sanitizeTealiumGlobals();
                  logTealiumPayload('[Tealium] utag.link', payload);
                  return originalLink(payload, cb, uid);
              };
          }
          window.__utagSanitized = true;
      }

      function initTealium() {
          if (typeof tealium_data2track !== 'undefined' && typeof tealium_data2track.push === 'function') {
              clearInterval(tealiumInterval);
              patchTealiumPush();
              patchUtag();
              sanitizePayload(tealiumData);
              sanitizeTealiumGlobals();
              setupEventHandlers();
              if(tealiumData.Page_Section2 != 'store-locator'){
                pushPageView();
              }
          }
      }


      function createProductsObject(cartData, variant) {
          let variantAddedComparePrice = cartData.discounted_price;
          if (variant?.compare_at_price != null) {
              variantAddedComparePrice = variant.compare_at_price;
          }

          return {
              Products: {
                  [cartData.product_id]: {
                      status: 'Available',
                      Price: (cartData.discounted_price / 100).toFixed(2),
                      PriceNet: (cartData.discounted_price / 100).toFixed(2),
                      PriceFull: (variantAddedComparePrice / 100).toFixed(2),
                      PriceFullNet: (variantAddedComparePrice / 100).toFixed(2),
                      Units: (cartData.quantity)?.toString()
                  }
              }
          };
      }

      function setupEventHandlers() {

        document.addEventListener("la:dn:cart:updated", async function(event) {
            const localStorageKey = "discountNinjaItems";
            const localStorageItems = JSON.parse(localStorage.getItem(localStorageKey)) || [];
            const cartItems = event.detail.data[0].items;
            const localStorageKeys = new Set(localStorageItems.map(item => item.key));
            const newItems = cartItems.filter(item => !localStorageKeys.has(item.key));

            localStorage.setItem(localStorageKey, JSON.stringify(cartItems));

            if (cartItems.length <= localStorageItems.length) return;

            const newFrames = newItems.filter(item => !item.parentRelationship?.parentKey);
            const newRxLenses = newItems.filter(item => item.parentRelationship?.parentKey);

            const lastAddedProduct = newFrames.reduce((latest, item) => {
              const itemAddedAt = item.properties?.find(p => p.name === '_cart_added_at')?.value || 0;
              const latestAddedAt = latest?.properties?.find(p => p.name === '_cart_added_at')?.value || 0;
              return itemAddedAt > latestAddedAt ? item : latest;
            }, newFrames[0]);
            
            console.log('[DN cart] lastAddedProduct:', lastAddedProduct);

            const tealiumProductId = String(lastAddedProduct?.product?.sku || lastAddedProduct?.product?.variantId || "").trim();
            if (!tealiumProductId) return;

            const lensUpc = newRxLenses.find(lens => lens.parentRelationship?.parentKey === lastAddedProduct.key)?.product?.sku || "";

            const lensFinalPrice = newRxLenses.find(lens => lens.parentRelationship?.parentKey === lastAddedProduct.key)?.price?.product?.discounted || 0;
            const lensOriginalPrice = newRxLenses.find(lens => lens.parentRelationship?.parentKey === lastAddedProduct.key)?.price?.product?.original || 0;
            const totalFinalPrice = (lastAddedProduct.price?.product?.discounted || lastAddedProduct.price?.product?.original) + lensFinalPrice;
            const totalOriginalPrice = (lastAddedProduct.price?.product?.original || 0) + lensOriginalPrice;

            const obj = {
                id: "Event",
                Events_CartAdd: "1",
                Products: {
                    [tealiumProductId]: {
                        Status: lastAddedProduct.product.available ? "Available" : "SoldOut",
                        LensType: lastAddedProduct.product.type === 'Accessories' ? '' : lastAddedProduct.properties.find(prop => prop.name === "_lens_type")?.value || "PLANO",
                        Price: `${(totalFinalPrice / 100)?.toFixed(2)}`,
                        PriceFull: `${(totalOriginalPrice / 100)?.toFixed(2)}`,
                        Category: lastAddedProduct.product?.type?.toUpperCase() || "",
                        LensUPC: lensUpc,
                        TaxRate: "",
                        Units: `${lastAddedProduct.quantity}`
                    }
                }
            }
            Fetchutils.sendTealiumData(obj);
        });

        

          subscribe(PUB_SUB_EVENTS.facetsUpdate, async (payload) => {
              tealium_data2track.push({
                  'id': 'Event',
                  ...payload
              });
          });

          subscribe(PUB_SUB_EVENTS.searchSubmit , async (payload) => {
              tealium_data2track.push({
                  'id': 'Event',
                  ...payload
              });
          });

          subscribe(PUB_SUB_EVENTS.accountCreated , async (payload) => {
              tealium_data2track.push({
                  id: 'VirtualPage-View',
                  'Events_UserAccountNew': '1',
                  'Page_Type': 'Static',
                  'Page_Section1': 'Account',
                  'Page_Country': Shopify.country,
                  'Order_Currency': Shopify.currency.active,
                  'User_LoginStatus': 'Logged',
                  'User_LoginType': 'Standard',
                  ...payload,
              });
          });
        const bindNowOrLater = () => {
            const root = getTabLtRoot();
            if (root) attachTabLtListeners(root);
        };
        bindNowOrLater();

        const tabLtObserver = new MutationObserver(bindNowOrLater);
        tabLtObserver.observe(document.documentElement, { childList: true, subtree: true });
    }


    function sendTealiumEvent(payload) {
        try {
            if (typeof window.utag !== 'undefined') {
                sanitizePayload(payload);
                sanitizeTealiumGlobals();
                logTealiumPayload('[Tealium] sendTealiumEvent', payload);
                tealium_data2track.push(payload);
            } else if (window.top) {
                window.top.postMessage(payload, "*");
            }
        } catch (e) {
            console.warn('Tealium event error', e);
        }
    }

    function getTabLtRoot() {
        return document.querySelector('tab-lt') || document.querySelector('#tabLt');
    }

    function attachTabLtListeners(root) {
        if (!root || root.dataset.tealiumBound === 'true') return;
        root.dataset.tealiumBound = 'true';

        const inferElementId = (el) => {
            const ds = el.dataset || {};
            const direct = ds.elementId || ds.element_id;
            if (direct) return direct;

            const label = (el.getAttribute('aria-label') || el.textContent || '').toLowerCase();
            if (/book|prenota|reservar|rendez-vous|buchen|アポイントを予約/.test(label)) return 'OEE_BookNow';
            if (/call|chiama|telefono/.test(label) || el.href?.includes('tel:')) return 'OEE_CallNow';
            if (/direction|indicazioni|mappa|map/.test(label) || el.classList?.contains('directionlink')) return 'OEE_StoreGetDirections';
            if (/detail|dettagli/.test(label) || el.href?.includes('boutique')) return 'OEE_StoreDetails';
            return null;
        };

        root.addEventListener('click', (evt) => {
            const target = evt.target.closest('a,button,[role="button"]');
            if (!target) return;

            const data_element_id = inferElementId(target);
            if (!data_element_id) return;

            sendTealiumEvent({
                id: 'Click',
                'data_element_id': data_element_id
            });
        }, { passive: true });
    }

      function pushPageView() {
          let dataPreparationPromise = ensureNewsletterSubscriptionEmailMd5(tealiumData);

          if (typeof Shopify !== 'undefined') {
            
              tealiumData['Page_Country'] = Shopify.country;
            
              tealiumData['lang'] = Shopify.locale + '-' + Shopify.country;
          }

        

        
// Solution with cart token
        console.log("Tealium Data Page Type:", tealiumData.Page_Type);
          if (tealiumData.Page_Type !== "Plp" && tealiumData.Page_Type !== "Search") {  
            dataPreparationPromise.then(() => {
              tealium_data2track.push({
                  id: 'VirtualPage-View',
                  ...tealiumData,
                
                  ...errorData
                
              });
            });
          } else {
            const dnAvailable = typeof discountNinja !== 'undefined' && discountNinja?.api;
            let timeout = null;
            let dispatched = false;

            const resolveHitUpc = (hit) => {
              if (!hit || typeof hit !== "object") return "";
              const direct = hit.upc || hit.barcode || hit.sku || hit.variant_barcode || hit.variant_sku;
              if (direct) return Array.isArray(direct) ? String(direct[0] || "") : String(direct);
              if (Array.isArray(hit.variants) && hit.variants.length) {
                const v = hit.variants.find(v => v?.barcode || v?.sku) || hit.variants[0];
                const vUpc = v?.barcode || v?.sku;
                return vUpc ? String(vUpc) : "";
              }
              return "";
            };

            document.addEventListener('plp:cards-loaded', event => {
                const hits = event.detail.hits || [];
                
                tealiumData.Products = tealiumData.Products || {};

                for (let hit of hits) {
                  const upc = resolveHitUpc(hit);
                  const productId = upc || String(hit.objectID || "");
                  const productPayload = {
                    "LensType": "PLANO",
                    "Price": (Math.round(hit.price) / 100).toFixed(2),
                    "PriceFull": (Math.round(hit.price) / 100).toFixed(2),
                    "Status": hit.inventory_available ? "Available" : "Out-of-stock",
                    handle: hit.handle
                  };
                  if (upc) productPayload.Upc = upc;
                  tealiumData.Products[productId] = productPayload;
                }

                if (!dnAvailable && !dispatched) {
                  dispatched = true;
                  tealium_data2track.push({
                      id: 'VirtualPage-View',
                      ...tealiumData
                  });
                }
            });

            if (dnAvailable) {
              document.addEventListener('la:dn:product:discount:calculated', event => {
                  const data = event.detail.data[0];
  
                  for (let id in tealiumData.Products) {
                    const product = tealiumData.Products[id];
  
                    if (product.handle === data.productHandle) {
                      const original = (Math.round(data.originalPrice) / 100).toFixed(2);
                      const discounted = (Math.round(data.discountedPrice) / 100).toFixed(2);
  
                      product["Price"] = discounted;
                      product["PriceFull"] = original;
                      delete product.handle;
  
                      timeout = setTimeout(() => {
                        if (!dispatched) {
                          dispatched = true;
                          tealium_data2track.push({
                              id: 'VirtualPage-View',
                              ...tealiumData
                          });
                        }
                      }, 500);
  
                      break;
                    }
                  }
              });
            }
          }}

      document.addEventListener('DOMContentLoaded', function () {
          tealiumInterval = setInterval(initTealium, 100);
      });

      function checkConsentValues(consent) {
        
        if(consent.hasOwnProperty("c1") && consent.hasOwnProperty("c7") && consent.hasOwnProperty("c9")) {
          if(consent['c1'] == '0' && consent['c7'] == '1' && consent['c9'] == '0' ) {
            return false
          } else {
            return true
          }
        }
        else {
          return true
        }
      }

      TealiumConsentCallBack = function() {
        // Read Tealium Cookie Consent
        if(window.utag && utag.gdpr && utag.gdpr.consent_prompt && utag.gdpr.consent_prompt.isEnabled && typeof utag.gdpr.getCookieValues === 'function'){
          // Get User Consent Info
          var tealiumConsent = utag.gdpr.getCookieValues() || {};
          // User Opted
          if(tealiumConsent.consent == "true") {
            if(checkConsentValues(tealiumConsent)) {
              window.Shopify.customerPrivacy.setTrackingConsent(
                {
                  "analytics": true,
                  "marketing": true,
                  "preferences": true
                },
                () => {
                  console.log('consent setted')
                  window.location.reload()
                }
              );
            }
          }
          //console.log('TEALIUM CONSENT:', tealiumConsent);
        }
      }
  </script>

