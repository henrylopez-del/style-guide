          <p class="copyright__content tw-typo-op-xs tw-text-op-secondary-dark">
            Pictures and images on this website are for illustration purposes only. No qualities or characteristics of the products depicted herein could be inferred from the relevant pictures.
          </p>
          <div class="tw-flex md:tw-justify-center tw-items-center tw-gap-x-4">
            <span class="tw-inline-flex tw-hidden">
              <svg width="17" height="17" viewBox="0 0 17 17" fill="none" xmlns="http://www.w3.org/2000/svg">
<rect x="1" y="1" width="15" height="15" fill="#F8F8FB" stroke="#9747FF" stroke-dasharray="5 5"/>
</svg>

            </span>
            <p class="copyright__content tw-typo-op-cta-small tw-text-op-action-link-secondary">
              WebId # 858876477
            </p>
            <span class="tw-inline-flex tw-hidden">
              <svg width="17" height="17" viewBox="0 0 17 17" fill="none" xmlns="http://www.w3.org/2000/svg">
<rect x="1" y="1" width="15" height="15" fill="#F8F8FB" stroke="#9747FF" stroke-dasharray="5 5"/>
</svg>

            </span>
          </div>
          
        </div>
      </div>
    </div>
  </footer>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const otherSites = document.querySelector('.other-sites-accordion details');
      const otherSitesContent = document.querySelector('.other-sites-accordion .op-accordion-content');
      const newDiv = document.createElement('div');
      if (otherSites) {
        otherSites.addEventListener('click', function () {
          if (!otherSites.open) {
            if (otherSitesContent) {
              newDiv.classList.add('tw-pb-md');
              newDiv.innerHTML = otherSitesContent.innerHTML;
              const copyrightBlock = document.querySelector('.footer__copyright');
              if (copyrightBlock) {
                copyrightBlock.parentNode.insertBefore(newDiv, copyrightBlock);
                otherSitesContent.style.display = 'none';
              }
            }
          } else {
            newDiv.remove();
          }
        });
      }
    });
  </script>





</div>
