<style data-shopify>
    #headerSearch-sections--26457650725199__header {
        display: none;
    }

    #headerSearch-sections--26457650725199__header.show {
        display: block;
    }

    body:has(#headerSearch-sections--26457650725199__header.show) {
        overflow: hidden;
    }
    
    body:has(#headerSearch-sections--26457650725199__header.show)::-webkit-scrollbar {
        display: none;
    }

    .algolia-search-suggestions .aa-ItemContent:before {
      content: "";
      display: inline-block;
      width: 16px;
      height: 16px;
      background-image: url('//www.oliverpeoples.com/cdn/shop/t/2/assets/op-icon-search.svg?v=130353951499856074101758708272');
      background-size: contain;
      background-repeat: no-repeat;
    }

    .aa-DetachedContainer .aa-Panel {
      display: flex;
      flex-direction: column;
      overflow-y: auto;
    }

    .aa-DetachedContainer .aa-Panel .aa-PanelLayout {
      background: white;
      z-index: 11;
      overflow-y: unset;
      position: relative;
