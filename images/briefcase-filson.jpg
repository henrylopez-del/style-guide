</div><div id="shopify-section-sections--21507134619800__search-preview" class="shopify-section shopify-section-group-header-group"><form
  class="tw-bg-background"
  style="
    position: fixed;
    top: var(--header-height);
    left: 0;
    right: 0;
    z-index: 9999;
  "
  x-transition.opacity
  x-show="$store.main.isSearchOpen"
  x-cloak
  :action="$store.autocomplete.redirectUrl ? $store.autocomplete.redirectUrl : '/search'"
  method="get"
>
  <div
    class="container tw-overflow-auto tw-pb-5 md:tw-pb-0"
    style="max-height: calc(100vh - var(--header-height));"
  >
    <div
      class="search-input__wrapper tw-py-4 tw-border-x-0 tw-border-y-2 tw-border-dotted tw-border-border"
    >
      <input
        type="search"
        class="search-input__field tw-text-center"
        autofocus
        name="q"
        placeholder="SEARCH"
        aria-label="Search"
        x-model="$store.autocomplete.searchInput"
        @input.debounce.500ms="$store.autocomplete.searchChange()"
        autocomplete="off"
      >
    </div>

    <template x-if="!$store.autocomplete.wasSearchPerformed && !$store.autocomplete.loading">
      <div
        class="tw-pt-6 md:tw-grid tw-grid-cols-1 tw-gap-5 md:tw-grid-cols-3 tw-flex tw-flex-col-reverse"
      >
        <div class="md:tw-flex tw-gap-5 tw-justify-between">
  <section
    x-show="$store.autocomplete.trendingQueries.length > 0"
    class="predictive-search__suggestions tw-flex-1"
  >
    <div
      class="predictive-search__column"
    >
      <p class="predictive-search__suggestions-title tw-border-t-2 tw-border-0 tw-border-dotted tw-border-border tw-pt-6 md:tw-pt-0 md:tw-border-t-0">
        Popular Searches
      </p>
      <ul class="predictive-search__suggestions-links list-reset">
        <template
          x-for="query in $store.autocomplete.trendingQueries"
          :key="query.searchQuery"
        >
          <li>
            <a
              :href="'/search?q=' + query.searchQuery"
              class="predictive-search__suggestions-link tw-capitalize"
              x-text="query.searchQuery"
            ></a>
          </li>
        </template>
      </ul>
    </div>
  </section>

  <div class="search-preview__column tw-flex-1">
    <p class="predictive-search__suggestions-title tw-border-t-2 tw-border-0 tw-border-dotted tw-border-border tw-pt-6 md:tw-pt-0 md:tw-border-t-0">
      Support
    </p>
    
