        url('https://c1.sfdcstatic.com/etc/clientlibs/sfdc-aem-master/clientlibs_base/fonts/SalesforceSans-Regular.ttf') format('truetype');
    }
</style>

<script type='text/javascript' src='https://service.force.com/embeddedservice/5.0/esw.min.js'></script>
<script type='text/javascript'>
    var initESW = function(gslbBaseURL) {
        embedded_svc.settings.displayHelpButton = true; //Or false
        embedded_svc.settings.language = ''; //For example, enter 'en' or 'en-US'

        //embedded_svc.settings.defaultMinimizedText = '...'; //(Defaults to Chat with an Expert)
        //embedded_svc.settings.disabledMinimizedText = '...'; //(Defaults to Agent Offline)

        //embedded_svc.settings.loadingText = ''; //(Defaults to Loading)
        //embedded_svc.settings.storageDomain = 'yourdomain.com'; //(Sets the domain for your deployment so that visitors can navigate subdomains during a chat session)

        // Settings for Chat
        //embedded_svc.settings.directToButtonRouting = function(prechatFormData) {
            // Dynamically changes the button ID based on what the visitor enters in the pre-chat form.
            // Returns a valid button ID.
        //};
        //embedded_svc.settings.prepopulatedPrechatFields = {}; //Sets the auto-population of pre-chat form fields
        //embedded_svc.settings.fallbackRouting = []; //An array of button IDs, user IDs, or userId_buttonId
        //embedded_svc.settings.offlineSupportMinimizedText = '...'; //(Defaults to Contact Us)

        embedded_svc.settings.enabledFeatures = ['LiveAgent'];
        embedded_svc.settings.entryFeature = 'LiveAgent';

        embedded_svc.init(
            'https://bedrockmfg.my.salesforce.com',
            'https://bedrockmfg.my.salesforce-sites.com/',
            gslbBaseURL,
            '00D1N000002aSk9',
            'Filson_Snap_In_Chat',
            {
                baseLiveAgentContentURL: 'https://c.la11-core1.sfdc-8tgtt5.salesforceliveagent.com/content',
                deploymentId: '5721N000000fyZE',
                buttonId: '5731N000000fyOd',
                baseLiveAgentURL: 'https://d.la11-core1.sfdc-8tgtt5.salesforceliveagent.com/chat',
                eswLiveAgentDevName: 'EmbeddedServiceLiveAgent_Parent04I1N0000008Sw2UAE_1690157bc67',
                isOfflineSupportEnabled: true
            }
        );
    };

    if (!window.embedded_svc) {
        var s = document.createElement('script');
        s.setAttribute('src', 'https://bedrockmfg.my.salesforce.com/embeddedservice/5.0/esw.min.js');
        s.onload = function() {
            initESW(null);
        };
        document.body.appendChild(s);
    } else {
        initESW('https://service.force.com');
    }
</script>
    

    <script>
	var SHOPIFY_DOMAIN = "cb3d2b-00.myshopify.com";
	var CART = {"note":null,"attributes":{},"original_total_price":0,"total_price":0,"total_discount":0,"total_weight":0.0,"item_count":0,"items":[],"requires_shipping":false,"currency":"USD","items_subtotal_price":0,"cart_level_discount_applications":[],"checkout_charge_amount":0};
	var TEMPLATE = "404"
	var KLAVIYO_LIST_ID = "";
	var KLAVIYO_COMPANY_ID = "S9Qc5f";

	
		var CUSTOMER_EMAIL = null;
	

  var CURRENCY = {
    "money_format": "${{amount}}",
    "iso_code": "USD",
    "name": "United States Dollar",
    "symbol": "$",
  };

	var GLOBALS = {
    PRODUCTS_SITE_ID: 'm6y09d',
    BLOG_SITE_ID: 'hbx9sz',
	};

	var EXCLUDED_PAGE_HANDLES = [
    // Store pages
    'our-stores',
    'canfield-store',
    'chicago-store',
    'seattle-store',
    'new-york-city-store',
    'washington-dc-store',
    'toronto-store',
    'naperville-store',
    'edina-store',
    'ballard-store',
    'san-francisco-store',
    'vancouver-store',
    'boston-store',
    'los-angeles-store',
    'eagan-outlet-store',
    'milan-store',
    'cortina-store',
    'portland-store',
    // Wholesale
    'group-sales',
    'authorized-dealers',

    // Utility
    'pro-program',
    'vip-texts',
    'about-us',

    // Customer care
    'customer-care',
    'unfailing-guarantee',
    'returns',
    'shipping',
    'repair-request-form',
    'repairs',
    'contact',
  ];

</script>


    <link href="//www.filson.com/cdn/shop/t/362/assets/quantity-popover.css?v=129068967981937647381779403192" rel="stylesheet" type="text/css" media="all" />
<link href="//www.filson.com/cdn/shop/t/362/assets/component-card.css?v=137011744709642899191779403109" rel="stylesheet" type="text/css" media="all" />

<style>
  .drawer {
    visibility: hidden;
  }
</style>

<div
  x-data
  x-cloak
  x-transition.opacity
  id="CartDrawer-Overlay"
  class="cart-drawer__overlay"
  x-show="$store.main.isMiniCartOpen && !$store.main.isRebuyEnabled()"
  @click="$store.main.setMiniCartOpen(false)"
></div>


<div
  x-data
  x-cloak
  x-trap="($store.main.isMiniCartOpen && !$store.main.isRebuyEnabled())"
  @keydown.escape="$store.main.setMiniCartOpen(false)"
  class="drawer"
  :class="{
    active: ($store.main.isMiniCartOpen && !$store.main.isRebuyEnabled()),
    'is-empty': !$store.main.cart.item_count
  }"
>
  <div id="CartDrawer" class="cart-drawer">
    <div
      class="drawer__inner gradient color-scheme-1"
      role="dialog"
      aria-modal="true"
      aria-label="Cart"
      tabindex="-1"
    >
      <div
        x-show="$store.main.cart.item_count"
        class="drawer__header"
      >
        <div class="cart-drawer-new__heading">
          Cart

          <span x-show="$store.main.cart.item_count > 0">
            [<span x-text="$store.main.cart.item_count"></span>]
          </span>
        </div>
        <button
          class="cart-drawer-new__close"
          type="button"
          @click="$store.main.setMiniCartOpen(false)"
          aria-label="Close"
        >
          <span class="svg-wrapper">
            <span class="screenreader">Close drawer</span>
            <i class="icon icon--drawer-close"></i>
          </span>
        </button>
      </div>

      <div x-show="!$store.main.cart.item_count">
        <div class="cart-drawer-new__empty-close">
          <button
            class="cart-drawer-new__close"
            type="button"
            @click="$store.main.setMiniCartOpen(false)"
            aria-label="Close"
          >
            <span class="svg-wrapper">
              <span class="screenreader">Close drawer</span>
              <i class="icon icon--drawer-close"></i>
            </span>
          </button>
        </div>
        <div class="drawer__inner-empty">
          <div class="cart-drawer__warnings center">
            <div class="cart-drawer__empty-content">
              <p class="cart-new__empty-text">Your cart is empty.</p><div class="cart-new__empty-text-account">
                  Have an account? <a href="https://www.filson.com/customer_authentication/redirect?locale=en&region_country=US" class="link underlined-link">Log in</a> to check out faster.
                </div><a href="/collections/all" class="cart-new__continue-btn">
                <span>Continue shopping</span>
              </a>
            </div>
          </div></div>
      </div>

      <div class="cart-drawer-new__container">
        <template x-if="$store.main.cart.item_count > 0">
          <div>
            



  <div
    class="cart-free-shipping ge-hide"
    x-data="{ threshold: 9900 }"
  >
    <div class="cart-free-shipping__progress">
      <div
        class="cart-free-shipping__progress-bar"
        :style="`--progress: ${Math.min(100, ($store.main.cart.total_price / threshold) * 100)}%`"
      ></div>
    </div>
    <div class="cart-free-shipping__message">
      <template x-if="threshold - $store.main.cart.total_price > 0">
        <span>
          You're <span x-price="threshold - $store.main.cart.total_price"></span> away from free shipping
        </span>
      </template>
      <template x-if="threshold - $store.main.cart.total_price <= 0">
        <span>Your order qualifies for free U.S. Shipping</span>
      </template>
    </div>
  </div>



            

            <cart-drawer-items class="cart__contents cart-drawer__form">
              <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
                <div class="cart-items" role="list">
                  <div class="cart-items-container">
                    <template
                      x-for="item in $store.main.cart.items"
                      :key="item.key"
                    >
                      <div class="cart-item-new cart-new__dotted-top" role="listitem">
                        <div class="cart-item-new__media">
                          <a :href="item.url" class="cart-item-new__link" aria-hidden="true" tabindex="-1"> </a>
                          <template x-if="item.featured_image?.url">
                            <div class="cart-item-new__image-container">
                              <img
                                class="cart-item-new__image"
                                :alt="item.product_title"
                                :src="item.featured_image?.url"
                                loading="lazy"
                              >
                            </div>
                          </template>
                        </div>

                        <div class="cart-item-new__details-container">
                          <div class="cart-item-new__details">
                            <div class="cart-item-new__details-left"><a
                                :href="item.url"
                                class="cart-item-new__name"
                                x-text="item.product_title.split(' - ')[0]"
                              ></a>

                              <template x-if="!item.product_has_only_default_variant || Object.keys(item.properties).length > 0 || item.selling_plan_allocation">
                                <div>
                                  <dl class="cart-item-new__description-list">
                                    <template x-for="option in item.options_with_values" :key="option.name">
                                      <div x-show="!item.product_has_only_default_variant" class="cart-item-new__product-option">
                                        <dd x-text="option.value"></dd>
                                      </div>
                                    </template>

                                    <template x-for="[key, value] in Object.entries(item.properties).filter(([k, v]) => v && !k.startsWith('_'))" :key="key">
                                      <div class="cart-item-new__product-option">
                                        <dt x-text="key + ':'"></dt>
                                        <dd>
                                          <template x-if="value.includes('/uploads/')">
                                            <a :href="value" class="link" target="_blank" x-text="value.split('/').pop()"></a>
                                          </template>
                                          <template x-if="!value.includes('/uploads/')">
                                            <span x-text="value"></span>
                                          </template>
                                        </dd>
                                      </div>
                                    </template>
                                  </dl>

                                  <template x-if="item.selling_plan_allocation">
                                    <p class="product-option" x-text="item.selling_plan_allocation.selling_plan.name"></p>
                                  </template>
                                </div>
                              </template>

                              <ul x-show="item.line_level_discount_allocations.length > 0" class="discounts list-unstyled" role="list" aria-label="Discount">
                                <template x-for="discount in item.line_level_discount_allocations" :key="discount.discount_application.title">
                                  <li class="discounts__discount"><svg class="icon icon-discount" viewBox="0 0 12 12"><path fill="currentColor" fill-rule="evenodd" d="M7 0h3a2 2 0 0 1 2 2v3a1 1 0 0 1-.3.7l-6 6a1 1 0 0 1-1.4 0l-4-4a1 1 0 0 1 0-1.4l6-6A1 1 0 0 1 7 0m2 2a1 1 0 1 0 2 0 1 1 0 0 0-2 0" clip-rule="evenodd"/></svg>
<span x-text="discount.discount_application.title"></span>
                                  </li>
                                </template>
                              </ul>
                            </div>

                            <div class="cart-item-new__details-right">
                              <template x-if="item.original_price !== item.final_price">
                                <div class="cart-item-new__discounted-prices">
                                  <span class="visually-hidden">
                                    Sale price
                                  </span>
                                  <strong class="cart-item-new__final-price product-option" x-price="item.final_line_price"></strong>
                                  <span class="visually-hidden">
                                    Regular price
                                  </span>
                                  <s class="cart-item-new__old-price product-option" x-price="item.original_line_price"></s>
                                </div>
                              </template>
                              <template x-if="item.original_price === item.final_price">
                                <div class="cart-item-new__price">
                                  <span class="product-option" x-price="item.original_line_price"></span>
                                </div>
                              </template>
                            </div>
                          </div>


                          <div class="cart-item-new__quantity cart-item-new__quantity--drawer">
                            <div class="cart-item-new__quantity-wrapper">
                              <div class="quantity-popover-container">
                                <div class="cart-item-new__quantity">
                                  <button
                                    class="cart-item-new__quantity-button quantity__button"
                                    name="minus"
                                    type="button"
                                    :aria-label="`Remove 1 ${item.product_title} from cart`"
                                    :class="{ loading: $store.main.pendingUpdateVariantId == item.variant_id }"
                                    :disabled="$store.main.pendingUpdateVariantId == item.variant_id"
                                    @click="$store.main.updateLineQuantity(item, item.quantity - 1)"
                                  >
                                    <span class="svg-wrapper">
                                      <span class="screenreader">Decrease quantity</span>
                                      <i class="icon icon--quantity-minus"></i>
                                    </span>
                                  </button>
                                  <input
                                    class="cart-item-new__quantity-input quantity__input"
                                    type="number"
                                    :value="item.quantity"
                                    readonly
                                  >
                                  <button
                                    class="cart-item-new__quantity-button quantity__button"
                                    name="plus"
                                    type="button"
                                    :aria-label="`Add 1 ${item.product_title} to cart`"
                                    :class="{ loading: $store.main.pendingUpdateVariantId == item.variant_id }"
                                    :disabled="$store.main.pendingUpdateVariantId == item.variant_id"
                                    @click="$store.main.updateLineQuantity(item, item.quantity + 1)"
                                  >
                                    <span class="svg-wrapper">
                                      <span class="screenreader">Increase quantity</span>
                                      <i class="icon icon--quantity-plus"></i>
                                    </span>
                                  </button>
                                </div>
                              </div>

                              <button
                                type="button"
                                class="cart-item-new__remove"
                                :aria-label="`Remove ${item.product_title} from cart`"
                                :class="{ loading: $store.main.pendingUpdateVariantId == item.variant_id }"
                                :disabled="$store.main.pendingUpdateVariantId == item.variant_id"
                                @click="$store.main.updateLineQuantity(item, 0)"
                              >
                                <span class="svg-wrapper">
                                  <i class="icon icon--cart-remove"></i>
                                </span>
                              </button>
                            </div>
                          </div>
                        </div>
                      </div>
                    </template>
                  </div>
                </div>
              </div>
            </cart-drawer-items>
          </div>
        </template>

        
      </div>

      <div class="drawer__footer"><!-- Start blocks -->
        <!-- Subtotals -->

        <div class="cart-drawer__footer" >
          <div>
            <ul x-show="$store.main.cart.cart_level_discount_applications?.length > 0" class="discounts list-unstyled" role="list" aria-label="Discount">
              <template x-for="discount in $store.main.cart.cart_level_discount_applications" :key="discount.title">
                <li class="discounts__discount discounts__discount--end"><svg class="icon icon-discount" viewBox="0 0 12 12"><path fill="currentColor" fill-rule="evenodd" d="M7 0h3a2 2 0 0 1 2 2v3a1 1 0 0 1-.3.7l-6 6a1 1 0 0 1-1.4 0l-4-4a1 1 0 0 1 0-1.4l6-6A1 1 0 0 1 7 0m2 2a1 1 0 1 0 2 0 1 1 0 0 0-2 0" clip-rule="evenodd"/></svg>
<span x-text="discount.title"></span>
                  (-<span x-price="discount.total_allocated_amount"></span>)
                </li>
              </template>
            </ul>
          </div>
        </div>

        <!-- CTAs -->
        <template x-if="$store.main.cart.item_count">
          <div class="cart__ctas" >
            <button
              type="button"
              @click="$store.main.navigateToCheckout($event)"
              class="cart-new__checkout-button"
              name="checkout"
              form="CartDrawer-Form"
            >
              <span x-text="$store.main.isNavigatingToCheckout ? 'Checking out…' : 'Checkout'"></span>
              <span x-price="$store.main.cart.total_price"></span>
            </button>
          </div>
        </template>
      </div>
    </div>
  </div>
</div>

  <style> .embeddedServiceHelpButton .helpButton .uiButton {background-color: #2a2a22; min-width: inherit; border-radius: 1px;} .embeddedServiceHelpButton .helpButton {bottom: 128px; right: 8px; height: 32px; -webkit-font-smoothing: antialiased;} .helpButtonLabel {display: none !important;} .embeddedServiceSidebar.layout-docked .dockableContainer {right: 8px; bottom: 8px;} .embeddedServiceHelpButton .embeddedServiceIcon {margin-right: 0px;} .header-new__nav-link {padding-left: 0.625rem;} </style>
</body>
</html>
