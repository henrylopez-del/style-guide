    <style>
template[data-ssr-id] + div[data-ssr-id] { visibility: hidden; }
</style>
<script>
(() => {
  try {
    const w = window.innerWidth || document.documentElement.clientWidth;
    document.querySelectorAll('div[data-ssr-id]').forEach(root => {
      if (root.parentElement?.closest('.fpls[data-id]')) return;
      const id = root.getAttribute('data-ssr-id');
      let best, bestMin = -Infinity;

      document.querySelectorAll('template[data-ssr-id="' + id + '"]').forEach(t => {
        const min = t.hasAttribute('data-min') ? +t.getAttribute('data-min') : null;
        const max = t.hasAttribute('data-max') ? +t.getAttribute('data-max') : null;

        if ((min == null || w >= min) && (max == null || w <= max)) {
          const score = min ?? -Infinity;
          if (score > bestMin) { bestMin = score; best = t; }
        }
      });

      if (best) root.replaceChildren(best.content.cloneNode(true));
      document.querySelectorAll('template[data-ssr-id="' + id + '"]').forEach(t => t.remove());
    });

    function scale(outer) {
      var g = outer.querySelector('.fpls-grid');
      var bw = +g.dataset.width;
      if (!bw) return;
      var z = outer.offsetWidth / bw;
      outer.querySelectorAll('[data-width]').forEach(function (el) {
        el.style.width = el.dataset.width * z + 'px';
        if (el.dataset.height) el.style.height = el.dataset.height * z + 'px';
        if (el.dataset.left != null) el.style.left = el.dataset.left * z + 'px';
        if (el.dataset.top != null) el.style.top = el.dataset.top * z + 'px';
        var box = el.firstElementChild;
        if (box && box.classList.contains('fpls-box')) box.style.transform = 'scale(' + z + ')';
      });
    }

    document.querySelectorAll('.fpls-grid--outer').forEach(scale);
  } catch (e) {
    console.error(e);
  }
})();
</script>
